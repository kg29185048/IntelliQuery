# Normalize line endings
* text=auto

# Shell scripts must stay LF
*.sh text eol=lf

# CSS/JS/JSX/HTML — normalize to LF
*.css text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf

# Python files — normalize to LF
*.py text eol=lf

# Binary files — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
